# koe-tts Environment Configuration
# Copy to .env and fill in values (never commit .env)
#   cp .env.example .env

# ── Storage Paths ──────────────────────────────────────────────
# Archive storage (NAS, external drive, or repo root)
# Omit or leave empty to use repo root as default
# KOE_DATA_ROOT=/mnt/nas/koe-tts

# Local working storage (fast SSD for active training)
# Omit or leave empty to use the same location as KOE_DATA_ROOT
# KOE_LOCAL_ROOT=/home/user/koe-tts

# ── Unity Catalog ──────────────────────────────────────────────

# Database password for UC's PostgreSQL backend
UC_DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# Path to Delta Lake storage (mounted in container as /lake)
LAKE_PATH=/path/to/your/lake

# UC Server URL (base URL for Spark/DuckDB)
UC_SERVER_URL=http://127.0.0.1:8080

# UC API URL (full REST path for Python client)
UC_API_URL=http://127.0.0.1:8080/api/2.1/unity-catalog

# UC auth token (leave empty until auth is enabled)
UC_TOKEN=

# Enable UC integration in application code (default: false)
UC_ENABLED=false
